# ─── K2 / Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
K2_MODEL=claude-opus-4-7            # or claude-sonnet-4-6 for faster/cheaper

# ─── Backend ─────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── Scene ───────────────────────────────────────────────────────
DEFAULT_SCENE=avery_house           # hardcoded scene id loaded on startup

# ─── Solar / Lighting sim ─────────────────────────────────────────
SCENE_LATITUDE=34.0195              # Caltech (Pasadena, CA)
SCENE_LONGITUDE=-118.1212
